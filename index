  .hero-btns{flex-direction:column}
  .btn-gold,.btn-ghost{text-align:center;width:100%;padding:.85rem 1rem}
  section{padding:4rem 4%}
  .gallery{padding:4rem 0}
  .gallery-head{padding:0 4%}
  .gallery-grid{padding:0 4%;gap:3px}
}
</style>
</head>
