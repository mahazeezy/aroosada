<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#0a0806;
  --gold:#c9a84c;
  --gold-light:#e2c47a;
  --gold-dark:#8b6914;
  --cream:#fdf8f0;
  --warm:#f5ede0;
  --text:#1a1510;
  --mid:#6b5d4f;
  --white:#fff;
  --border:rgba(201,168,76,.25);
}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;color:var(--text);background:var(--black);overflow-x:hidden;-webkit-text-size-adjust:100%}
img{display:block;width:100%;object-fit:cover}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:.9rem 5%;background:rgba(10,8,6,.88);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:var(--gold);letter-spacing:.12em;text-transform:uppercase}
.nav-logo span{font-weight:400;font-style:italic;color:var(--gold-light);font-size:1rem;display:block;letter-spacing:.2em;margin-top:-.2rem}
.nav-links{display:flex;gap:2rem;align-items:center}
.nav-links a{font-size:.75rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.7);transition:color .2s}
.nav-links a:hover{color:var(--gold)}
.nav-cta{background:var(--gold)!important;color:var(--black)!important;padding:.45rem 1.1rem;font-weight:600!important}
.nav-cta:hover{background:var(--gold-light)!important}
.nav-phone{display:none;background:var(--gold);color:var(--black);padding:.4rem 1rem;font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase}

/* HERO */
.hero{position:relative;height:100svh;min-height:600px;overflow:hidden;margin-top:0}
.hero-bg{position:absolute;inset:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center 20%;transform:scale(1.04);animation:heroZoom 12s ease forwards}
@keyframes heroZoom{to{transform:scale(1)}}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(160deg,rgba(10,8,6,.85) 0%,rgba(10,8,6,.6) 50%,rgba(10,8,6,.2) 100%)}
.hero-content{position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 6%;padding-top:80px;max-width:700px}
.hero-eyebrow{font-size:.7rem;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;display:flex;align-items:center;gap:.8rem}
.hero-eyebrow::before{content:'';width:32px;height:1px;background:var(--gold)}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,8vw,6rem);font-weight:700;color:var(--white);line-height:1;letter-spacing:.04em;margin-bottom:.4rem}
.hero h1 em{color:var(--gold);font-style:italic;display:block}
.hero-sub{font-size:clamp(.9rem,2.5vw,1.05rem);color:rgba(255,255,255,.7);line-height:1.8;margin:1.2rem 0 2.2rem;max-width:480px;font-weight:300;letter-spacing:.04em}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.btn-gold{background:var(--gold);color:var(--black);padding:.85rem 2rem;font-family:'Jost',sans-serif;font-size:.78rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;transition:all .25s;display:inline-block}
.btn-gold:hover{background:var(--gold-light)}
.btn-ghost{border:1px solid rgba(201,168,76,.6);color:var(--gold);padding:.85rem 2rem;font-size:.78rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;transition:all .25s;display:inline-block}
.btn-ghost:hover{border-color:var(--gold);background:rgba(201,168,76,.08)}
.hero-scroll{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(255,255,255,.4);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase}
.hero-scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollLine 2s ease-in-out infinite}
@keyframes scrollLine{0%,100%{opacity:.4;transform:scaleY(1)}50%{opacity:1;transform:scaleY(.6)}}

/* TICKER */
.ticker{background:var(--gold);overflow:hidden;padding:.55rem 0;white-space:nowrap}
.ticker-inner{display:inline-flex;animation:ticker 20s linear infinite}
.ticker-inner span{padding:0 2rem;color:var(--black);font-size:.7rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase}
.ticker-inner .sep{color:rgba(10,8,6,.4);padding:0}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* SECTION BASE */
section{padding:6rem 5%}
.s-label{font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:.8rem;display:flex;align-items:center;gap:.7rem}
.s-label::before{content:'';width:24px;height:1px;background:var(--gold)}
.s-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:600;line-height:1.1;margin-bottom:1rem}
.s-body{font-size:.92rem;line-height:1.9;color:var(--mid);font-weight:300;letter-spacing:.03em}

/* ABOUT */
.about{background:var(--cream)}
.about-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;max-width:1100px;margin:0 auto}
.about-img-wrap{position:relative}
.about-img-main{aspect-ratio:3/4;overflow:hidden}
.about-img-main img{height:100%}
.about-img-accent{position:absolute;bottom:-2rem;right:-2rem;width:55%;aspect-ratio:1;overflow:hidden;border:6px solid var(--cream)}
.about-text .s-body{margin-bottom:1.5rem}
.about-detail{display:flex;align-items:center;gap:.8rem;margin-bottom:.8rem;font-size:.85rem;color:var(--mid)}
.about-detail-icon{width:32px;height:32px;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}

/* SERVICES */
.services{background:var(--black)}
.services-head{text-align:center;margin-bottom:3.5rem}
.services-head .s-title{color:var(--white)}
.services-head .s-label{justify-content:center}
.services-head .s-label::before{display:none}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);max-width:1100px;margin:0 auto}
.svc-card{background:var(--black);padding:2.5rem 2rem;text-align:center;transition:background .3s;position:relative;overflow:hidden}
.svc-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform .4s;transform-origin:left}
.svc-card:hover{background:#12100d}
.svc-card:hover::before{transform:scaleX(1)}
.svc-icon{font-size:2rem;margin-bottom:1rem}
.svc-name{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;color:var(--gold);margin-bottom:.6rem;letter-spacing:.08em}
.svc-desc{font-size:.82rem;color:rgba(255,255,255,.5);line-height:1.8;font-weight:300}

/* GALLERY */
.gallery{background:var(--warm);padding:6rem 0}
.gallery-head{padding:0 5%;margin-bottom:2.5rem}
.gallery-grid{display:grid;grid-template-columns:2fr 1fr;grid-template-rows:380px 280px;gap:4px;padding:0 5%}
.g-item{overflow:hidden;position:relative}
.g-item.span2{grid-column:1/3}
.g-item img{height:100%;transition:transform .6s ease}
.g-item:hover img{transform:scale(1.04)}
.g-item-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,8,6,.6) 0%,transparent 50%);opacity:0;transition:opacity .3s}
.g-item:hover .g-item-overlay{opacity:1}

/* HOURS */
.hours{background:var(--black)}
.hours-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;max-width:1000px;margin:0 auto}
.hours .s-title{color:var(--white)}
.hours-table{margin-top:1.5rem}
.h-row{display:flex;justify-content:space-between;align-items:center;padding:.75rem 0;border-bottom:1px solid rgba(201,168,76,.12);font-size:.85rem}
.h-row:last-child{border:none}
.h-day{color:rgba(255,255,255,.55);letter-spacing:.08em;font-weight:300}
.h-time{color:var(--gold);font-weight:500;letter-spacing:.06em}
.h-closed{color:rgba(255,255,255,.25);font-style:italic}
.hours-cta{margin-top:2rem;display:flex;flex-direction:column;gap:1rem}
.contact-line{display:flex;align-items:center;gap:.9rem;color:rgba(255,255,255,.65);font-size:.88rem;font-weight:300}
.contact-icon{width:36px;height:36px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;color:var(--gold)}

/* CTA BANNER */
.cta-band{background:linear-gradient(135deg,var(--gold-dark) 0%,var(--gold) 50%,var(--gold-light) 100%);padding:4rem 5%;text-align:center}
.cta-band h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3rem);font-weight:700;color:var(--black);margin-bottom:.6rem;letter-spacing:.04em}
.cta-band p{color:rgba(10,8,6,.7);font-size:.92rem;margin-bottom:2rem;font-weight:300;letter-spacing:.06em}
.btn-dark{background:var(--black);color:var(--gold);padding:.9rem 2.4rem;font-size:.78rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;transition:all .25s;display:inline-block}
.btn-dark:hover{background:#1a1510}

/* FOOTER */
footer{background:#050403;padding:3rem 5% 1.5rem;border-top:1px solid var(--border)}
.footer-top{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
.footer-brand{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--gold);letter-spacing:.12em;margin-bottom:.5rem}
.footer-tagline{font-size:.78rem;color:rgba(255,255,255,.35);letter-spacing:.15em;text-transform:uppercase;font-weight:300}
.footer-col h4{font-size:.68rem;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
.footer-col a,.footer-col p{display:block;font-size:.82rem;color:rgba(255,255,255,.45);margin-bottom:.5rem;font-weight:300;transition:color .2s}
.footer-col a:hover{color:var(--gold)}
.footer-bottom{padding-top:1.2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem}
.footer-bottom p{font-size:.68rem;color:rgba(255,255,255,.2);letter-spacing:.1em}

/* SCROLL REVEAL */
.reveal{opacity:0;transform:translateY(32px);transition:opacity .7s ease,transform .7s ease}
.reveal-l{opacity:0;transform:translateX(-40px);transition:opacity .75s ease,transform .75s ease}
.reveal-r{opacity:0;transform:translateX(40px);transition:opacity .75s ease,transform .75s ease}
.reveal.vis,.reveal-l.vis,.reveal-r.vis{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}

/* MOBILE */
@media(max-width:768px){
  .nav-links{display:none}
  .nav-phone{display:block}
  .about-inner{grid-template-columns:1fr;gap:3rem}
  .about-img-accent{display:none}
  .services-grid{grid-template-columns:1fr}
  .gallery-grid{grid-template-columns:1fr;grid-template-rows:280px 240px 240px;padding:0 4%}
  .g-item.span2{grid-column:auto}
  .hours-inner{grid-template-columns:1fr;gap:2rem}
  .footer-top{grid-template-columns:1fr;gap:1.8rem}
}
@media(max-width:480px){
  nav{padding:.8rem 4%}
  .hero-content{padding:0 5%;padding-top:70px}
